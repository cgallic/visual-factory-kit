{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-factory.local/schemas/visual-request.schema.json",
  "title": "Visual Factory Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "client", "content_id", "formats", "message", "proof", "output"],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 3
    },
    "client": {
      "type": "string",
      "minLength": 2
    },
    "content_id": {
      "type": "string",
      "minLength": 3
    },
    "content_type": {
      "type": "string"
    },
    "distribution": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "default": []
    },
    "formats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      },
      "uniqueItems": true
    },
    "topic": {
      "type": "string"
    },
    "audience": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "persona": { "type": "string" },
        "industry": { "type": "string" },
        "funnel_stage": { "type": "string" }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline"],
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "subhead": {
          "type": "string",
          "maxLength": 180
        },
        "supporting_copy": {
          "type": "string",
          "maxLength": 180
        },
        "proof_label": {
          "type": "string",
          "maxLength": 80
        },
        "cta": {
          "type": "string",
          "maxLength": 48
        },
        "phone_number": {
          "type": "string",
          "maxLength": 32
        },
        "phone_label": {
          "type": "string",
          "maxLength": 32
        }
      }
    },
    "proof": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "source_path"],
        "properties": {
          "proof_id": { "type": "string" },
          "claim": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120
          },
          "source_type": {
            "type": "string",
            "default": "manual"
          },
          "source_path": {
            "type": "string",
            "minLength": 3
          },
          "display_as": {
            "type": "string",
            "enum": ["stat", "label", "source", "quote"],
            "default": "stat"
          },
          "verified_by": { "type": "string" },
          "verified_at": { "type": "string" },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "default": "low"
          }
        }
      }
    },
    "visual_direction": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "template_family": { "type": "string" },
        "mascot_role": { "type": "string" },
        "preferred_pose": { "type": "string" },
        "mood": { "type": "string" },
        "avoid": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pii_allowed": { "type": "boolean", "default": false },
        "ai_disclosure_needed": { "type": "string" },
        "claims_verified": { "type": "boolean" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alt_text", "destination_dir"],
      "properties": {
        "alt_text": {
          "type": "string",
          "minLength": 12,
          "maxLength": 240
        },
        "destination_dir": {
          "type": "string",
          "minLength": 3
        },
        "filename_prefix": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        }
      }
    }
  }
}
